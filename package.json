{
  "name": "persian-gateways",
  "version": "0.2.0",
  "description": "nodejs module for using persian gateways",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bmi": {
      "types": "./dist/modules/bmi/bmi.d.ts",
      "import": "./dist/modules/bmi/bmi.js"
    },
    "./bpm": {
      "types": "./dist/modules/bpm/bpm.d.ts",
      "import": "./dist/modules/bpm/bpm.js"
    },
    "./sep": {
      "types": "./dist/modules/sep/sep.d.ts",
      "import": "./dist/modules/sep/sep.js"
    },
    "./zarinpal": {
      "types": "./dist/modules/zarinpal/zarinpal.d.ts",
      "import": "./dist/modules/zarinpal/zarinpal.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "node --watch --env-file-if-exists=.env src/index.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "prepack": "npm run type-check && npm run lint && npm run build",
    "pack:dry": "npm pack --dry-run",
    "prepare": "husky",
    "start": "node --env-file=.env src/index.ts",
    "test": "npm run type-check"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "prettier --write",
      "eslint --fix",
      "git add"
    ]
  },
  "type": "module",
  "keywords": [
    "payment",
    "gateway",
    "iran",
    "persian",
    "zarinpal",
    "bmi",
    "sadad",
    "bank-melli",
    "mellat",
    "sep"
  ],
  "author": "miladmxm",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miladmxm/persian-gateways.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "dependencies": {
    "soap": "1.9.1"
  },
  "devDependencies": {
    "@fullstacksjs/eslint-config": "13.10.0",
    "@types/node": "^25.6.0",
    "eslint": "9.37.0",
    "husky": "9.1.7",
    "lint-staged": "16.2.3",
    "prettier": "3.6.2",
    "typescript": "5.8.3"
  }
}
