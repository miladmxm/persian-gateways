{
  "name": "persian-gateways",
  "version": "1.0.0",
  "description": "nodejs module for using persian gateways",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "node --watch --env-file-if-exists=.env src/index.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "prepare": "husky",
    "start": "node --env-file=.env src/index.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "prettier --write",
      "eslint --fix",
      "git add"
    ]
  },
  "type": "module",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {},
  "devDependencies": {
    "@fullstacksjs/eslint-config": "13.10.0",
    "eslint": "9.37.0",
    "@types/node": "^25.6.0",
    "husky": "9.1.7",
    "lint-staged": "16.2.3",
    "prettier": "3.6.2",
    "typescript": "5.8.3"
  }
}
