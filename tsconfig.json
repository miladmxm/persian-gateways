{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ESNext",
    "module": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "verbatimModuleSyntax": false,
    "rewriteRelativeImportExtensions": true,
    "types": [
      "node"
    ],
    "jsx": "react-jsx",
    "outDir": "./dist"
  },
  "exclude": [
    "node_modules"
  ]
}
